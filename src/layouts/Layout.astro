---
import "../app.css";

import MonumentExtendedBlack from "$lib/fonts/MonumentExtended/MonumentExtended-Black.woff2";
import "@fontsource/inter/400.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/jetbrains-mono/400.css";

import Badge from "../components/Badge.astro";
import Grid from "../components/Grid.astro";
import SocialIcons from "../components/SocialIcons.astro";
import MailingListForm from "../components/MailingListForm.astro";
import HeaderMenu from "../components/HeaderMenu.astro";

import CommaIcon from "$lib/icons/comma.svg?raw";
import CartIcon from "$lib/icons/ui/cart.svg?raw";
import BasketIcon from "$lib/icons/ui/basket.svg?raw";
import ExternalIcon from "$lib/icons/ui/external.svg?raw";

interface Props {
  title?: string;
}

const { title = "comma.ai — make driving chill" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- analytics -->
    <script defer data-domain="comma.ai" src="https://plausible.io/js/script.js"></script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NKN922YQ1D"></script>
