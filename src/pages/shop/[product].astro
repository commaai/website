---
import Layout from "../../layouts/Layout.astro";
import NoteCard from "../../components/NoteCard.astro";
import Product from "../../components/Product.astro";
import CarHarnessProduct from "../../components/ProductDescriptions/CarHarness.astro";

import { getProduct } from '$lib/utils/shopify';
import { products as productsData } from '$lib/data/products.js';
import { resolveImages } from '$lib/utils/images.js';

export function getStaticPaths() {
  // Generate paths for all products that have routes and aren't handled by explicit pages
  const explicitPages = ['comma-four', 'body', 'comma-four-trade-in'];
  const paths = Object.entries(productsData)
    .filter(([slug, product]: [string, any]) => {
      return product.route && product.category && !explicitPages.includes(slug);
    })
    .map(([slug, product]: [string, any]) => ({
      params: { product: slug },
    }));

  return paths;
}

const { product: productSlug } = Astro.params;
const productInfo = productsData[productSlug];

if (!productInfo) {
  return Astro.redirect('/404');
}

// Resolve image imports
const resolvedImages = productInfo.images ? resolveImages(productInfo.images) : [];

// Fetch from Shopify
let product: any = { ...productInfo, images: resolvedImages };

try {
  const response = await getProduct(productInfo.id);
  if (response.status === 200) {
    const shopifyProduct = response.body?.data?.product;
    if (shopifyProduct) {
      product = {
        ...shopifyProduct,
        ...productInfo,
        images: resolvedImages
      };
    }
  }
} catch (e) {
  console.error(`Failed to fetch product ${productSlug}:`, e);
}

import { imgSrc } from "$lib/utils/img.js";

const productImages = product.images || [];
const firstImgSrc = productImages.length > 0 ? imgSrc(productImages[0]) : '';
---

<Layout title={`${product.title} — comma shop`}>
  <section class="light" id="product-item">
    <div class="container">
      {productSlug === 'car-harness' ? (
        <CarHarnessProduct product={product} />
      ) : (
        <Product
          product={product}
          backordered={product.backordered || null}
          forceOutOfStock={product.forceOutOfStock || false}
          hideOutOfStockVariants={product.hideOutOfStockVariants || false}
        >
          <div slot="notes">
            {(product.notes || []).map((note) => (
              <NoteCard title={note.title}>
                <Fragment set:html={note.content} />
              </NoteCard>
            ))}
          </div>
          <div slot="description">
            {product.description && (
              <Fragment set:html={product.description} />
            )}
          </div>
        </Product>
      )}
    </div>
  </section>
</Layout>

<script>
  import { addToCart } from '../../store';

  // Image thumbnail switching
  document.querySelectorAll('.thumbnail').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = (btn as HTMLElement).dataset.src;
      const mainImg = document.getElementById('main-product-image') as HTMLImageElement;
      if (mainImg && src) {
        mainImg.src = src;
      }
      document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // Variant selection
  let selectedVariantId: string | null = null;
  const variantBtns = document.querySelectorAll('.variant-btn');
  if (variantBtns.length > 0) {
    // Select first available variant
    const firstAvailable = document.querySelector('.variant-btn:not([disabled])') as HTMLElement;
    if (firstAvailable) {
      firstAvailable.classList.add('selected');
      selectedVariantId = firstAvailable.dataset.variantId || null;
    }
  }

  variantBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      variantBtns.forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      selectedVariantId = (btn as HTMLElement).dataset.variantId || null;
    });
  });

  // Add to cart
  const addToCartBtn = document.getElementById('add-to-cart');
  if (addToCartBtn) {
    addToCartBtn.addEventListener('click', () => {
      if (selectedVariantId) {
        addToCart(selectedVariantId);
      } else if (variantBtns.length === 0) {
        // No variants, try getting the first variant from the product data
        const productMount = document.querySelector('[data-product]') as HTMLElement;
        if (productMount) {
          try {
            const productData = JSON.parse(productMount.dataset.product || '{}');
            if (productData.variants?.edges?.[0]?.node?.id) {
              addToCart(productData.variants.edges[0].node.id);
            }
          } catch (e) {
            console.error('Failed to parse product data:', e);
          }
        }
      }
    });
  }
</script>

<style>
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;

    @media screen and (max-width: 768px) {
      grid-template-columns: 1fr;
    }
  }

  .product-images {
    & .main-image {
      border: 1px solid rgba(0, 0, 0, 0.12);
      padding: 1rem;
      margin-bottom: 1rem;

      & img {
        width: 100%;
        height: auto;
        object-fit: contain;
      }
    }
  }

  .thumbnail-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .thumbnail {
    border: 1px solid rgba(0, 0, 0, 0.12);
    padding: 0.5rem;
    cursor: pointer;
    background: white;
    width: 80px;
    height: 80px;

    &.active, &:hover {
      border-color: black;
    }

    & img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  }

  .product-info {
    & h1 {
      font-size: 2rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
  }

  .product-price {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .backordered {
    color: var(--color-red, #c00);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .variants {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .variant-btn {
    border: 1px solid #000;
    padding: 0.5rem 1rem;
    cursor: pointer;
    background: white;
    font-size: 1rem;
    transition: all 0.2s;

    &.selected {
      background: black;
      color: white;
    }

    &:hover:not([disabled]) {
      background: #eee;
    }

    &.selected:hover {
      background: black;
    }

    &[disabled] {
      opacity: 0.5;
      cursor: not-allowed;
    }

    & .out-of-stock {
      font-size: 0.75rem;
      opacity: 0.65;
    }
  }

  .add-to-cart-btn {
    background-color: var(--color-accent);
    color: black;
    border: none;
    padding: 1rem 2rem;
    font-size: 1.125rem;
    font-weight: 600;
    cursor: pointer;
    text-transform: uppercase;
    width: 100%;
    transition: background-color 0.2s;

    &:hover {
      background-color: var(--color-accent-hover);
    }

    &.out-of-stock-btn {
      opacity: 0.5;
      cursor: not-allowed;
    }
  }

  .notes-section {
    margin-top: 1.5rem;
  }

  .product-description {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    line-height: 1.6;

    & :global(strong) {
      display: block;
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    & :global(hr) {
      margin: 1.5rem 0;
      border: none;
      border-top: 1px solid rgba(0, 0, 0, 0.15);
    }

    & :global(hgroup) {
      margin: 1rem 0;

      & :global(span) {
        font-family: JetBrains Mono, monospace;
        font-size: 0.875rem;
        text-transform: uppercase;
        opacity: 0.65;
      }

      & :global(strong) {
        font-size: 1.25rem;
        margin-top: 0.25rem;
      }
    }
  }
</style>
