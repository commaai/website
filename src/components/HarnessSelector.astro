---
import NoteCard from "./NoteCard.astro";
import CarIcon from "$lib/icons/features/car.svg?raw";

const {
  id = `harness-${(Math.random() * 10e15).toString(16)}`,
  label = "Select vehicle",
  placeholder = "Search for a vehicle or harness",
  showNoHarnessOption = false,
  showVehicleHarnesses = true,
  showGenericHarnesses = true,
  hideSupportNoteCard = false,
  restoreSelection = false,
  accessoryTemplate = "",
} = Astro.props;
---
<div
  class="harness-selector"
  id={id}
  data-label={label}
  data-placeholder={placeholder}
  data-show-no-harness-option={showNoHarnessOption ? '1' : '0'}
  data-show-vehicle-harnesses={showVehicleHarnesses ? '1' : '0'}
  data-show-generic-harnesses={showGenericHarnesses ? '1' : '0'}
  data-restore-selection={restoreSelection ? '1' : '0'}
  data-accessory-template={accessoryTemplate}
>
  <div class="dropdown">
    <div class="dropdown-value">
      <div class="selection-placeholder" role="button" tabindex="0">
        <div class="label">{label}</div>
        <div class="accessory"></div>
      </div>
    </div>
    <span class="chevron">
      <svg width="18" height="12" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 12L0 3L1.5 1.5L9 9L16.5 1.5L18 3L9 12Z" fill="currentColor"/>
      </svg>
    </span>
    <div class="dropdown-content"></div>
  </div>

  {!hideSupportNoteCard && (
    <div class="harness-support-note" style="display: none;">
      <NoteCard title="Support" icon={CarIcon}>
        <span class="note-body"></span>
      </NoteCard>
    </div>
  )}
</div>

<script>
  import "$scripts/harness-selector.js";
</script>

<style>
  .dropdown {
    position: relative;
    display: inline-block;
    margin: 1.25rem auto 0;
    width: 100%;
  }

  .dropdown-value {
    width: 100%;
  }

  :global(.dropdown-content) {
    display: none;
    position: absolute;
    border: 1px solid #ddd;
    z-index: 1;
    width: 100%;
    max-height: 400px;
    overflow-y: auto;
    background: #fff;
  }

  :global(.dropdown-content.show) {
    display: block;
  }

  :global(.search-input) {
    box-sizing: border-box;
    width: 100%;
    min-height: 84px;
    border: 1px solid #a0a0a0;
    padding: 14px;
    outline: none;
    font-size: 1rem;
  }

  :global(.search-input::placeholder) {
    font-size: 1rem;
    color: #656565;
  }

  :global(.selection-placeholder) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    color: #222222;
    background-color: #fff;
    border: 1px solid #a0a0a0;
    padding: 1rem 3rem 1rem 1.5rem;
    box-sizing: border-box;
    min-height: 84px;
    transition: border-color 0.2s;
  }

  :global(.selection-placeholder:hover) {
    border-color: #464646;
  }

  :global(.selection-placeholder .label) {
    font-size: 1rem;
    font-weight: 600;
    color: #515151;
    text-wrap: balance;
  }

  :global(.selection-placeholder .accessory) {
    font-size: 1.25rem;
    font-weight: 600;
    text-wrap: nowrap;
  }

  .chevron {
    position: absolute;
    top: 50%;
    right: 13px;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .chevron > :global(svg) {
    width: 18px;
    height: 12px;
  }

  :global(.harness-clear) {
    position: absolute;
    left: 13px;
    height: 100%;
    padding: 0;
    cursor: pointer;
    background-color: transparent;
    border: none;
    z-index: 2;
  }

  :global(.dropdown-item) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    color: #222222;
    background-color: #fff;
    border: 1px solid #a0a0a0;
    padding: 1.25rem 3rem;
    box-sizing: border-box;
    min-height: 84px;
    transition: border-color 0.2s;
  }

  :global(.dropdown-item:hover) {
    border-color: #464646;
  }

  :global(.dropdown-item .item-info) {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  :global(.dropdown-item-title) {
    font-size: 1rem;
    font-weight: 600;
    margin-right: 0.5rem;
  }

  :global(.dropdown-item-subtitle) {
    font-size: 0.875rem;
    font-weight: 400;
    color: rgb(81, 81, 81);
    margin-right: 0.5rem;
  }

  :global(.accessory-label) {
    font-size: 1.25rem;
    font-weight: 600;
    text-wrap: nowrap;
  }
</style>
