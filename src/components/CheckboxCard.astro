---
import NoteCard from "./NoteCard.astro";

interface Props {
  title: string;
  checked?: boolean;
  disabled?: boolean;
}

const { title, checked = false, disabled = false } = Astro.props;
---

<label class:list={["checkbox-card", { checked }, { disabled }]}>
  <NoteCard title={title}>
    <input type="checkbox" slot="icon" checked={checked} disabled={disabled} />
    <slot />
  </NoteCard>
</label>

<style>
  .checkbox-card {
    cursor: pointer;
    display: block;
    color: green;
  }

  .checkbox-card.disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .checkbox-card :global(input[type="checkbox"]) {
    width: 1.25rem;
    height: 1.25rem;
    cursor: pointer;
    accent-color: var(--color-accent);
  }

  .checkbox-card.disabled :global(input[type="checkbox"]) {
    cursor: not-allowed;
  }

  .checkbox-card.checked :global(.card hgroup span) {
    background-color: #86ff4e;
    color: black;
  }
</style>
