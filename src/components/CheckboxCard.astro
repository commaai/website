---
import NoteCard from "./NoteCard.astro";

const { title, checked = false, disabled = false, id, class: className = "" } = Astro.props;
---
<label class:list={["checkbox-card", { checked, disabled }, className]} data-id={id}>
  <NoteCard title={title}>
    <input slot="icon" type="checkbox" checked={checked || undefined} disabled={disabled || undefined} />
    <slot />
  </NoteCard>
</label>

<style>
  .checkbox-card {
    cursor: pointer;
    display: block;
    color: green;
  }

  .checkbox-card.disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }

  .checkbox-card :global(input[type="checkbox"]) {
    width: 1.25rem;
    height: 1.25rem;
    cursor: pointer;
    accent-color: var(--color-accent);
  }

  .checkbox-card.disabled :global(input[type="checkbox"]) {
    cursor: not-allowed;
  }

  .checkbox-card.checked :global(.note-card hgroup span) {
    background-color: #86ff4e;
    color: black;
  }
</style>
