---
const {
  id = (Math.random() * 10e15).toString(16),
  type = "checkbox",
  checked = false,
  style = "light",
  foregroundColor = null,
  backgroundColor = null,
  class: className = "",
} = Astro.props;

const fg = foregroundColor ?? (style === 'light' ? 'black' : 'white');
const bg = backgroundColor ?? (style === 'light' ? 'white' : 'black');
---
<div
  class:list={["accordion", className]}
  id={id}
  style={`--foreground-color: ${fg}; --background-color: ${bg};`}
>
  <input type={type} name={id} id={`acc-input-${id}`} checked={checked || undefined} />
  <label for={`acc-input-${id}`}>
    <slot name="label" />
    <span class="chevron">
      <svg width="18" height="12" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 12L0 3L1.5 1.5L9 9L16.5 1.5L18 3L9 12Z" fill="currentColor"/>
      </svg>
    </span>
  </label>
  <div class="accordion-content">
    <slot name="content" />
  </div>
</div>

<style>
  .accordion input {
    position: absolute;
    opacity: 0;
    z-index: -1;
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    color: var(--foreground-color);
    transition: max-height 0.6s cubic-bezier(0, 1, 0, 1);
  }

  .accordion input:checked ~ .accordion-content {
    max-height: 10000px;
    transition: max-height 0.6s ease-in-out;
    animation: allow-overflow 0.6s forwards;
  }

  @keyframes allow-overflow {
    0% {
      overflow: hidden;
    }
    99% {
      overflow: hidden;
    }
    100% {
      overflow: visible;
    }
  }

  label {
    cursor: pointer;
    display: grid;
    align-items: center;
    position: relative;
    background-color: var(--background-color);
    padding-right: 4rem;
  }

  label > :global(*) {
    color: var(--foreground-color);
  }

  .chevron {
    position: absolute;
    right: 2rem;
    transition: transform 0.6s;
    color: var(--foreground-color);
  }
  .chevron > :global(svg) {
    color: var(--foreground-color);
    width: 18px;
    height: 12px;
  }

  input:checked + label .chevron {
    transform: rotate(180deg);
  }
</style>
