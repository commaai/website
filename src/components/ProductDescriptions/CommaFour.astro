---
import Product from "../Product.astro";
import NoteCard from "../NoteCard.astro";
import Accordion from "../Accordion.astro";
import Badge from "../Badge.astro";

import ShippingIcon from "$lib/icons/features/shipping.svg?raw";
import MoneyBackGuaranteeIcon from "$lib/icons/features/money-back-guarantee.svg?raw";
import WarrantyIcon from "$lib/icons/features/warranty.svg?raw";

import { FOUR_PRICE } from '$lib/constants/prices.js';
import { formatCurrency } from "$lib/utils/currency";

interface Props {
  product: any;
}

const { product } = Astro.props;

const initialPrice = formatCurrency({ amount: FOUR_PRICE, currencyCode: 'USD' }, 0);
---

<div class="comma-four-product" data-four-price={FOUR_PRICE}>
  <Product
    product={product}
    backordered="1-12 weeks"
    priceOverride={FOUR_PRICE}
    disableBuyButtonText="SELECT YOUR CAR"
  >
    <div slot="shipping"></div>

    <div slot="price" class="price">
      <span class="main-price">{initialPrice}</span>
      <span class="price-due-today" style="display:none"></span>
    </div>

    <span slot="price-accessory">
      <div class="badge">
        <Badge style="dark">Free rush shipping</Badge>
      </div>

      <hr />

      <strong>Select a harness to connect the comma four to your car.</strong>
      <div
        class="harness-selector-area"
        data-label="Select your car"
        data-show-no-harness="true"
      ></div>
      <label class="checkbox-card" id="trade-in-checkbox">
        <div class="card">
          <input type="checkbox" disabled />
          <hgroup>
            <span>$250 credit with trade-in</span>
            <div>
              Get $250 credit when you trade in your old comma device. Any comma device, in any condition.
              <a href="/shop/comma-four-trade-in">Instructions and Terms</a>
            </div>
          </hgroup>
        </div>
      </label>
    </span>

    <div slot="notes">
      <NoteCard title="Upgrading from another comma device?">
        You do not need a new car harness. All comma devices use the same harness.
      </NoteCard>
    </div>

    <div slot="description">
      <div class="item">
        <Accordion>
          <div class="label" slot="label">
            <div><Fragment set:html={ShippingIcon} /></div>
            <span>Free Rush (UPS 2nd Day Air) shipping</span>
          </div>
          <div class="details" slot="content">
            US only. Rush orders are fulfilled on the next business day.
            <br /><br />
            International shipping is $30 flat rate.
            See fine print below for details. Common shipping questions are answered on
            <a href="/support#shipping--returns" target="_blank">the FAQ</a>.
          </div>
        </Accordion>
      </div>
      <div class="item">
        <Accordion>
          <div class="label" slot="label">
            <div><Fragment set:html={MoneyBackGuaranteeIcon} /></div>
            <span>Try our 30-day money-back trial</span>
          </div>
          <div class="details" slot="content">
            See for yourself why Consumer Reports rated us as the
            <a href="https://data.consumerreports.org/wp-content/uploads/2020/11/consumer-reports-active-driving-assistance-systems-november-16-2020.pdf">top driver assistance system</a>.
            We think you'll love it, but if you're not satisfied, send it back for a full refund.
          </div>
        </Accordion>
      </div>
      <div class="item">
        <Accordion>
          <div class="label" slot="label">
            <div><Fragment set:html={WarrantyIcon} /></div>
            <span>1-year hardware warranty</span>
          </div>
          <div class="details" slot="content">
            1-year limited warranty against hardware defects.
          </div>
        </Accordion>
      </div>
    </div>
  </Product>

  <!-- Disclaimer Modal -->
  <div class="modal-wrapper disclaimer-modal" style="display:none">
    <div class="backdrop">
      <div class="modal-container">
        <div tabindex="-1" class="modal">
          <span class="modal-title">Disclaimer</span>
          <p class="disclaimer no-harness-warning" style="display:none">
            A car harness is required to connect the comma four to your vehicle.
            You currently have no car harness selected.
          </p>
          <p class="disclaimer">
            The comma four does not ship with any software.
            Once you have the device you will be able to install any software you choose at your own risk.
          </p>
          <p class="disclaimer warning backorder-warning" style="display:none">
            The comma four is expected to ship out in 1-12 weeks.
            By adding this item to your cart you acknowledge that your order will be delayed.
          </p>
          <button class="modal-proceed-btn">Add to cart</button>
          <button class="modal-close-btn">Go back</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { allHarnesses } from '$lib/utils/harnesses';
  import { selectedCar } from '../../store';
  import { NO_HARNESS_OPTION } from '$lib/constants/vehicles.js';
  import { FOUR_PRICE } from '$lib/constants/prices.js';
  import { formatCurrency } from '$lib/utils/currency';
  import { products as productsData } from '$lib/data/products.js';
  import { getProduct } from '$lib/utils/shopify';

  document.querySelectorAll('.comma-four-product').forEach((container) => {
    const productEl = container.querySelector('.product-component');
    const disclaimerModal = container.querySelector('.disclaimer-modal');
    const modalProceedBtn = container.querySelector('.modal-proceed-btn');
    const modalCloseBtn = container.querySelector('.modal-close-btn');
    const modalBackdrop = container.querySelector('.backdrop');
    const noHarnessWarning = container.querySelector('.no-harness-warning');
    const backorderWarning = container.querySelector('.backorder-warning');
    const mainPriceEl = container.querySelector('.main-price');
    const priceDueTodayEl = container.querySelector('.price-due-today');
    const tradeInCheckbox = container.querySelector('#trade-in-checkbox input');
    const tradeInCard = container.querySelector('#trade-in-checkbox');

    let selectedHarness = null;
    let tradeInChecked = false;
    let tradeInVariantId = null;
    let backordered = '1-12 weeks';
    let disableBuyButtonText = 'SELECT YOUR CAR';
    let onProceed = null;

    const discountAmount = 50;
    const tradeInCredit = 250;

    // Build harness selector dynamically
    const harnessArea = container.querySelector('.harness-selector-area');
    if (harnessArea) {
      // Create a harness selector inline
      const selectorDiv = document.createElement('div');
      selectorDiv.className = 'inline-harness-selector';
      selectorDiv.innerHTML = `
        <div class="dropdown">
          <div class="dropdown-top" style="position:relative">
            <button class="hs-clear" style="display:none; position:absolute; left:13px; height:100%; padding:0; cursor:pointer; background:transparent; border:none; z-index:1">&times;</button>
            <div class="hs-placeholder" role="button" tabindex="0" style="display:flex; justify-content:space-between; align-items:center; cursor:pointer; color:#222; background:#fff; border:1px solid #a0a0a0; padding:1rem 3rem 1rem 1.5rem; box-sizing:border-box; min-height:84px; transition:border-color 0.2s;">
              <div style="font-size:1rem; font-weight:600; color:#515151">Select your car</div>
            </div>
            <input type="text" placeholder="Search for a vehicle or harness" autocomplete="off" class="hs-search" style="display:none; box-sizing:border-box; width:100%; min-height:84px; border:1px solid #a0a0a0; padding:14px 3rem; outline:none; font-size:1rem;" />
            <div class="hs-selected" style="display:none; cursor:pointer; color:#222; background:#fff; border:1px solid #a0a0a0; padding:1.25rem 3rem; box-sizing:border-box; min-height:84px;"></div>
          </div>
          <div class="hs-dropdown-content" style="display:none; position:absolute; border:1px solid #ddd; z-index:1; width:100%; max-height:400px; overflow-y:auto;"></div>
        </div>
      `;
      harnessArea.appendChild(selectorDiv);

      const hsPlaceholder = selectorDiv.querySelector('.hs-placeholder');
      const hsSearch = selectorDiv.querySelector('.hs-search');
      const hsSelected = selectorDiv.querySelector('.hs-selected');
      const hsClear = selectorDiv.querySelector('.hs-clear');
      const hsDropdownContent = selectorDiv.querySelector('.hs-dropdown-content');
      const hsDropdown = selectorDiv.querySelector('.dropdown');

      let menuOpen = false;
      let inputValue = '';
      let harnesses = [];

      function normalizeDiacritics(str) {
        return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      }

      function getFiltered() {
        if (!inputValue) return harnesses;
        return harnesses.filter(item =>
          normalizeDiacritics(item.car.toLowerCase()).match(normalizeDiacritics(inputValue.toLowerCase()))
        );
      }

      function renderHsDropdownItem(item) {
        const div = document.createElement('div');
        div.style.cssText = 'display:flex; justify-content:space-between; align-items:center; cursor:pointer; color:#222; background:#fff; border:1px solid #a0a0a0; padding:1.25rem 3rem; box-sizing:border-box; min-height:84px; transition:border-color 0.2s;';
        div.addEventListener('mouseenter', () => { div.style.borderColor = '#464646'; });
        div.addEventListener('mouseleave', () => { div.style.borderColor = '#a0a0a0'; });
        let subtitle = item.title ? `<div style="font-size:0.875rem; color:#515151;">Harness: ${item.title}</div>` : '';
        div.innerHTML = `<div><div style="font-size:1rem; font-weight:600;">${item.car || ''}</div>${subtitle}</div>`;
        return div;
      }

      function renderHsDropdown() {
        hsDropdownContent.innerHTML = '';
        if (!menuOpen) { hsDropdownContent.style.display = 'none'; return; }
        hsDropdownContent.style.display = 'block';

        const filtered = getFiltered();
        if (inputValue !== '') {
          if (filtered.length > 0) {
            filtered.forEach(item => {
              const el = renderHsDropdownItem(item);
              el.addEventListener('click', () => selectHarness(item));
              hsDropdownContent.appendChild(el);
            });
          } else {
            const el = renderHsDropdownItem({ car: 'No matching vehicles' });
            hsDropdownContent.appendChild(el);
          }
        } else {
          // Show "I already have a harness" option
          const noHarnessEl = renderHsDropdownItem(NO_HARNESS_OPTION);
          noHarnessEl.addEventListener('click', () => selectHarness(NO_HARNESS_OPTION));
          hsDropdownContent.appendChild(noHarnessEl);

          harnesses.forEach(item => {
            const el = renderHsDropdownItem(item);
            el.addEventListener('click', () => selectHarness(item));
            hsDropdownContent.appendChild(el);
          });
        }
      }

      function renderHsState() {
        if (menuOpen) {
          hsSearch.style.display = '';
          hsPlaceholder.style.display = 'none';
          hsSelected.style.display = 'none';
          hsClear.style.display = '';
        } else if (selectedHarness) {
          hsSearch.style.display = 'none';
          hsPlaceholder.style.display = 'none';
          hsSelected.style.display = '';
          hsClear.style.display = '';
          let subtitle = selectedHarness.title ? `<div style="font-size:0.875rem; color:#515151;">Harness: ${selectedHarness.title}</div>` : '';
          hsSelected.innerHTML = `<div><div style="font-size:1rem; font-weight:600;">${selectedHarness.car || ''}</div>${subtitle}</div>`;
        } else {
          hsSearch.style.display = 'none';
          hsPlaceholder.style.display = 'flex';
          hsSelected.style.display = 'none';
          hsClear.style.display = 'none';
        }
        renderHsDropdown();
      }

      function selectHarness(item) {
        selectedHarness = item;
        menuOpen = false;
        inputValue = '';
        hsSearch.value = '';

        handleHarnessSelection(item);
        renderHsState();
      }

      function clearHarness() {
        if (!inputValue) {
          menuOpen = false;
        } else {
          inputValue = '';
          hsSearch.value = '';
          hsSearch.focus();
        }
        selectedHarness = null;
        handleHarnessSelection(null);
        renderHsState();
      }

      hsClear.addEventListener('click', clearHarness);
      hsPlaceholder.addEventListener('click', () => { menuOpen = true; renderHsState(); hsSearch.focus(); });
      hsPlaceholder.addEventListener('keydown', (e) => { if (e.key === 'Enter') { menuOpen = true; renderHsState(); hsSearch.focus(); } });
      hsSelected.addEventListener('click', () => { menuOpen = true; renderHsState(); hsSearch.focus(); });

      hsSearch.addEventListener('input', () => { inputValue = hsSearch.value; renderHsDropdown(); });
      hsSearch.addEventListener('focus', () => { menuOpen = true; renderHsDropdown(); });

      document.addEventListener('click', (e) => {
        if (!hsDropdown.contains(e.target)) {
          menuOpen = false;
          renderHsState();
        }
      });

      // Subscribe to harness store
      allHarnesses.subscribe((val) => {
        harnesses = val || [];
        if (harnesses.length > 0) {
          const urlParams = new URLSearchParams(window.location.search);
          const carName = decodeURIComponent(urlParams.get('harness') || '');
          if (carName === NO_HARNESS_OPTION.car) {
            selectHarness(NO_HARNESS_OPTION);
          } else if (carName) {
            const found = harnesses.find(h => h.car === carName);
            if (found) selectHarness(found);
          }
        }
      });

      // Expose setSelection for autofill
      harnessArea._setSelection = function(sel) {
        selectHarness(sel);
      };
    }

    function handleHarnessSelection(value) {
      selectedHarness = value;
      if (value === NO_HARNESS_OPTION) {
        backordered = '1-12 weeks';
        disableBuyButtonText = null;
      } else if (value) {
        backordered = '1-12 weeks';
        disableBuyButtonText = null;
      } else {
        backordered = null;
        disableBuyButtonText = 'SELECT YOUR CAR';
      }

      // Reset trade-in if no selection
      if (!value && tradeInCheckbox) {
        tradeInCheckbox.checked = false;
        tradeInChecked = false;
      }

      if (value?.car) {
        selectedCar.set(value.car);
      } else {
        selectedCar.set('');
      }

      updatePriceDisplay();
      updateProductState();
    }

    function updatePriceDisplay() {
      const showDiscount = selectedHarness === NO_HARNESS_OPTION;
      const priceDueToday = showDiscount ? FOUR_PRICE - discountAmount : FOUR_PRICE;
      const priceAfterTradeIn = tradeInChecked ? priceDueToday - tradeInCredit : priceDueToday;

      if (mainPriceEl) {
        if (tradeInChecked && tradeInCredit > 0) {
          mainPriceEl.textContent = `${formatCurrency({ amount: priceAfterTradeIn, currencyCode: 'USD' }, 0)} after trade-in received`;
          if (priceDueTodayEl) {
            priceDueTodayEl.style.display = '';
            priceDueTodayEl.textContent = `(${formatCurrency({ amount: priceDueToday, currencyCode: 'USD' }, 0)} due today)`;
          }
        } else if (showDiscount && discountAmount > 0) {
          mainPriceEl.textContent = formatCurrency({ amount: priceDueToday, currencyCode: 'USD' }, 0);
          if (priceDueTodayEl) priceDueTodayEl.style.display = 'none';
        } else {
          mainPriceEl.textContent = formatCurrency({ amount: FOUR_PRICE, currencyCode: 'USD' }, 0);
          if (priceDueTodayEl) priceDueTodayEl.style.display = 'none';
        }
      }
    }

    function getAdditionalIds() {
      const ids = [];
      if (selectedHarness && selectedHarness !== NO_HARNESS_OPTION) {
        ids.push(selectedHarness.id);
      }
      if (tradeInChecked && tradeInVariantId) {
        ids.push(tradeInVariantId);
      }
      return ids;
    }

    function updateProductState() {
      if (!productEl) return;
      productEl.dispatchEvent(new CustomEvent('product-state-update', {
        detail: {
          disableBuyButtonText: disableBuyButtonText,
          backordered: backordered,
          additionalProductIds: getAdditionalIds(),
          priceOverride: FOUR_PRICE,
          beforeAddToCart: (addToCartFn) => {
            onProceed = () => {
              addToCartFn();
              disclaimerModal.style.display = 'none';
            };

            // Update modal warnings
            const hasAdditionalIds = getAdditionalIds().length === 0 && (!selectedHarness || selectedHarness === NO_HARNESS_OPTION);
            if (noHarnessWarning) noHarnessWarning.style.display = hasAdditionalIds ? '' : 'none';
            if (backorderWarning) backorderWarning.style.display = backordered ? '' : 'none';

            const proceedLabel = backordered ? `Add to cart (ships in ${backordered})` : 'Add to cart';
            if (modalProceedBtn) modalProceedBtn.textContent = proceedLabel;

            disclaimerModal.style.display = '';
          },
          getCartNote: () => {
            if (selectedHarness?.car) {
              const vehicle_note = `Vehicle: ${selectedHarness.car}`;
              const backordered_note = backordered ? `${backordered} backordered` : 'in stock';
              return `${vehicle_note} (${backordered_note})`;
            }
            return '';
          },
        }
      }));
    }

    // Trade-in checkbox
    if (tradeInCheckbox) {
      tradeInCheckbox.addEventListener('change', () => {
        if (disableBuyButtonText) return; // disabled
        tradeInChecked = tradeInCheckbox.checked;
        updatePriceDisplay();
        updateProductState();
      });

      tradeInCard.addEventListener('click', (e) => {
        if (e.target === tradeInCheckbox) return; // let native checkbox handle
        if (disableBuyButtonText) return;
        tradeInCheckbox.checked = !tradeInCheckbox.checked;
        tradeInChecked = tradeInCheckbox.checked;
        updatePriceDisplay();
        updateProductState();
      });
    }

    // Modal handlers
    if (modalProceedBtn) {
      modalProceedBtn.addEventListener('click', () => {
        if (onProceed) onProceed();
      });
    }
    if (modalCloseBtn) {
      modalCloseBtn.addEventListener('click', () => {
        disclaimerModal.style.display = 'none';
      });
    }
    if (modalBackdrop) {
      modalBackdrop.addEventListener('click', (e) => {
        const modal = disclaimerModal.querySelector('.modal');
        if (modal && !modal.contains(e.target)) {
          disclaimerModal.style.display = 'none';
        }
      });
    }

    // On mount: autofill trade-in + fetch trade-in product
    (async () => {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('trade-in') === '1') {
        if (tradeInCheckbox) {
          tradeInCheckbox.checked = true;
          tradeInChecked = true;
        }
        if (harnessArea?._setSelection) {
          harnessArea._setSelection(NO_HARNESS_OPTION);
        }
      }

      try {
        const tradeInProductId = productsData["comma-four-trade-in"]?.id;
        if (!tradeInProductId) return;
        const response = await getProduct(tradeInProductId);
        if (response.status === 200) {
          const tradeInProduct = response.body?.data?.product;
          if (tradeInProduct?.variants?.nodes?.length > 0) {
            tradeInVariantId = tradeInProduct.variants.nodes[0].id;
          }
        }
      } catch (error) {
        console.error('Failed to fetch trade-in product:', error);
      }
    })();
  });
</script>

<style>
  .item {
    padding: 1rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
  }

  .badge {
    margin: 1rem 0;
  }

  .label {
    display: flex;
    align-items: center;
    color: black;

    & div {
      height: 24px;
      width: 2.5rem;
    }

    & span {
      vertical-align: middle;
      margin-right: 1rem;
      color: black;
    }
  }

  .details {
    max-width: 80%;
    margin-left: 2.5rem;
    margin-top: 0.875rem;
  }

  .disclaimer {
    margin: 0;

    &.warning {
      color: #c53e3e;
      font-weight: 600;
    }
  }

  hr {
    margin: 2rem 0;
  }

  .price-due-today {
    font-size: 1rem;
    color: rgb(81, 81, 81);
  }

  /* Disclaimer Modal Styles */
  .modal-wrapper {
    position: fixed;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    z-index: 2000;
  }

  .backdrop {
    display: block;
    position: fixed;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
  }

  .modal-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .modal {
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    padding: 48px;
    max-width: 600px;
    max-height: 100%;
    overflow: auto;
    border-radius: 8px;
    text-align: center;
    background-color: rgb(255, 255, 255);
  }

  @media screen and (max-width: 768px) {
    .modal {
      margin: 1.25rem;
      padding: 1rem;
    }
  }

  .modal-title {
    font-size: 1.5rem;
    font-weight: 600;
  }

  .modal-proceed-btn,
  .modal-close-btn {
    border: none;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    justify-content: center;
    padding: 1.25rem 4rem;
    font-size: 1.125rem;
    font-weight: 600;
    display: flex;
    width: 100%;
    cursor: pointer;
    transition: all 0.2s;
  }

  .modal-proceed-btn {
    background-color: var(--color-accent);
    color: black;
  }

  .modal-close-btn {
    background-color: black;
    color: white;
  }

  /* Checkbox card */
  .checkbox-card {
    cursor: pointer;
    display: block;

    & .card {
      display: flex;
      margin: 1rem 0;
      padding: 1rem;
      align-items: center;
      color: black;
      border: 1px solid #616161;

      & input[type="checkbox"] {
        width: 1.25rem;
        height: 1.25rem;
        cursor: pointer;
        accent-color: var(--color-accent);
        margin-right: 1rem;
        flex-shrink: 0;
      }

      & hgroup {
        display: block;

        & span {
          font-family: JetBrains Mono, monospace;
          font-size: 0.875rem;
          font-weight: 400;
          text-transform: uppercase;
          line-height: 1.1;
          margin-bottom: 0.25rem;
          color: black;
        }

        & div {
          display: block;
          color: #000000A6;
          font-size: 0.875rem;
          line-height: 1.25;

          & a {
            color: black;
            border-bottom: 2px solid #616161;
          }
        }
      }
    }
  }

  .inline-harness-selector {
    margin: 1.25rem auto 0;
    width: 100%;
    position: relative;
  }
</style>
