---
import Accordion from './Accordion.astro';
import Grid from './Grid.astro';

const { topic, title = null } = Astro.props;
const headerTitle = title ?? topic.title;
const headerId = headerTitle.toLowerCase().replace(/[^\w\s]/g, '').replaceAll(' ', '-');
---
<div>
  <div class="header" id={headerId}>
    <Grid columns={2} alignItems="center" rowGap="0" size="small">
      <h1>{headerTitle}</h1>
      <div class="mobile-first">
        <img src={topic.image} loading="eager" alt={`${headerTitle} banner`} />
      </div>
    </Grid>
  </div>
  <div class="faq-questions">
    {topic.questions.map((entry: any) => {
      const id = entry.question.toLowerCase().replace(/[^\w\s]/g, '').replaceAll(' ', '-');
      return (
        <>
          <Accordion id={id}>
            <div slot="label" class="label">
              <span>{entry.question}</span>
            </div>
            <div class="details" slot="content" set:html={entry.answer} />
          </Accordion>
          <hr />
        </>
      );
    })}
  </div>
</div>

<style>
  .header {
    width: 100%;
    background-color: #000;
    margin-top: 2rem;
    margin-bottom: 2rem;

    & h1 {
      font-size: 3rem;
      font-weight: 600;
      margin: 1rem 2rem;
      color: white;
      text-wrap: balance;

      @media screen and (max-width: 1024px) {
        & {
          font-size: 2.5rem;
        }
      }

      @media screen and (max-width: 480px) {
        & {
          font-size: 2rem;
        }
      }

      @media screen and (max-width: 375px) {
        & {
          font-size: 1.5rem;
        }
      }
    }

    & img {
      color: white;
      width: 100%;
    }
  }

  .faq-questions {
    & .label {
      font-size: 1.25rem;
      font-weight: 600;
      margin: 1rem 0;
      margin-right: 0.75rem;
    }

    & :global(.details) {
      font-size: 1.25rem !important;
      line-height: 1.4;
      padding: 0.25rem 0 1rem;

      & *:first-child {
        margin-top: 0;
      }

      & *:last-child {
        margin-bottom: 0;
      }

      & a {
        color: #000;
        border-bottom: 2px solid #86ff4e;
        background-color: rgba(134, 255, 78, 0.15);
      }

      & li {
        font-size: 1.25rem;
      }

      & .video-container {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;

        & iframe {
          position: absolute;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
        }
      }
    }
  }
</style>
