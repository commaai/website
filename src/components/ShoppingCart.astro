---
interface Props {
  loading?: boolean;
}

const { loading = false } = Astro.props;
---

<div class="shopping-cart-wrapper" style="display:none">
  <div class="overlay" role="presentation"></div>
  <div class="sidemenu" role="dialog" aria-modal="true">
    <div class="header">
      <span>Your Cart</span>
      <button class="close-cart-btn">&times;</button>
    </div>
    <div class="inventory">
      <div class="empty">Your cart is empty.</div>
    </div>
    <div class="footer"></div>
  </div>
</div>

<script>
  import { cartItems, cartDiscount, cartSubtotal, checkoutUrl, showCart } from '../store.js';
  import { formatCurrency } from '$lib/utils/currency';

  function renderCart() {
    const wrapper = document.querySelector('.shopping-cart-wrapper');
    if (!wrapper) return;

    const isVisible = showCart.get();
    wrapper.style.display = isVisible ? '' : 'none';

    const items = cartItems.get() || [];
    const inventory = wrapper.querySelector('.inventory');
    const footer = wrapper.querySelector('.footer');

    // Render inventory
    if (items.length === 0) {
      inventory.innerHTML = '<div class="empty">Your cart is empty.</div>';
    } else {
      inventory.innerHTML = items.map(item => {
        const merchandise = item.node.merchandise;
        const product = merchandise.product;
        const imageSrc = product.images.edges[0]?.node.originalSrc || '';
        const variantTitle = merchandise.title !== "Default Title"
          ? `<div class="variant">${merchandise.title}</div>`
          : '';

        return `
          <div class="item">
            <img alt="${product.title}" decoding="async" loading="lazy" src="${imageSrc}" />
            <div class="details">
              <div class="title">${product.title}</div>
              ${variantTitle}
              <div style="height: 0.5rem"></div>
              <div class="steppable-input" data-variant-id="${merchandise.id}" data-line-id="${item.node.id}">
                <button class="step-dec" aria-label="Decrement quantity">-</button>
                <input type="number" min="0" aria-label="quantity" value="${item.node.quantity}" />
                <button class="step-inc" aria-label="Increment quantity">+</button>
              </div>
            </div>
            <div>${formatCurrency(item.node.estimatedCost.totalAmount)}</div>
          </div>
        `;
      }).join('');

      // Attach steppable input listeners
      inventory.querySelectorAll('.steppable-input').forEach(si => {
        const input = si.querySelector('input');
        const decBtn = si.querySelector('.step-dec');
        const incBtn = si.querySelector('.step-inc');
        const variantId = si.dataset.variantId;
        const lineId = si.dataset.lineId;

        function dispatchUpdate(quantity) {
          wrapper.dispatchEvent(new CustomEvent('updateProduct', {
            detail: { body: { variantId, quantity, lineId } },
            bubbles: true
          }));
        }

        decBtn.addEventListener('click', () => {
          const next = parseInt(input.value) - 1;
          input.value = next;
          dispatchUpdate(next);
        });

        incBtn.addEventListener('click', () => {
          const next = parseInt(input.value) + 1;
          input.value = next;
          dispatchUpdate(next);
        });

        input.addEventListener('change', () => {
          dispatchUpdate(parseInt(input.value));
        });
      });
    }

    // Render footer
    if (items.length === 0) {
      footer.innerHTML = '';
    } else {
      const discount = cartDiscount.get();
      const subtotal = cartSubtotal.get();
      let priceHtml = '';

      if (discount && discount.amount) {
        const subtotalAfterDiscount = subtotal.amount - discount.amount;
        priceHtml = `
          <div class="price">
            <span>Bulk Order Discount</span>
            <span>-${formatCurrency(discount)}</span>
          </div>
          <div class="price">
            <span>Subtotal</span>
            <span><s>${formatCurrency(subtotal)}</s> ${formatCurrency({ amount: subtotalAfterDiscount, currencyCode: subtotal.currencyCode })}</span>
          </div>
        `;
      } else if (subtotal) {
        priceHtml = `
          <div class="price">
            <span>Subtotal</span>
            <span>${formatCurrency(subtotal)}</span>
          </div>
        `;
      }

      footer.innerHTML = `
        ${priceHtml}
        <div class="disclaimer">
          Customs/duties/taxes are between you and your country.
        </div>
        <button class="checkout-btn">Checkout</button>
      `;

      const checkoutBtn = footer.querySelector('.checkout-btn');
      if (checkoutBtn) {
        checkoutBtn.addEventListener('click', () => {
          const url = checkoutUrl.get();
          if (url) window.open(url, '_self');
        });
      }
    }
  }

  // Subscribe to store changes
  showCart.subscribe(renderCart);
  cartItems.subscribe(renderCart);
  cartDiscount.subscribe(renderCart);
  cartSubtotal.subscribe(renderCart);

  // Close button and overlay
  document.addEventListener('click', (e) => {
    const wrapper = document.querySelector('.shopping-cart-wrapper');
    if (!wrapper) return;

    if (e.target.closest('.close-cart-btn') || e.target.closest('.overlay')) {
      showCart.set(false);
    }
  });
</script>

<style>
  .overlay {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    right: 0;
    z-index: 10;
  }

  .sidemenu {
    display: flex;
    flex-direction: column;
    position: fixed;
    right: 0;
    top: 6rem;
    bottom: 2rem;
    width: 340px;
    background-color: #fff;
    box-shadow: -5px 0 5px rgba(0, 0, 0, 0.1);
    z-index: 11;
    border-radius: 0.5rem 0 0 0.5rem;

    @media screen and (max-width: 1300px) {
      top: 9rem;
    }
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem 1rem 1rem;

    & span {
      font-size: 1.25rem;
      color: #000;
    }

    & button {
      background-color: transparent;
      border: none;
      cursor: pointer;
      font-size: 2rem;
    }
  }

  .inventory {
    flex-grow: 1;
    overflow-y: auto;
    padding: 1rem;

    & :global(.empty) {
      text-align: center;
    }

    & :global(.item) {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
      flex: 1;

      & :global(img) {
        width: 65px;
        height: auto;
      }

      & :global(.details) {
        flex: 1;
        margin: 0 0.75rem;

        & :global(.title) {
          font-size: 1rem;
          font-weight: bold;
        }

        & :global(.variant) {
          font-size: 0.875rem;
          opacity: 0.8;
        }
      }
    }
  }

  .footer {
    padding: 1rem;
    display: flex;
    flex-flow: column;
    gap: 1rem;

    & :global(.price) {
      display: flex;
      justify-content: space-between;
      font-size: 0.875rem;
      text-transform: uppercase;

      & :global(span) {
        color: #000;
      }

      & :global(s) {
        margin-right: 0.25rem;
      }
    }

    & :global(.disclaimer) {
      font-size: 0.75rem;
      text-align: center;
    }

    & :global(.checkout-btn) {
      background-color: var(--color-accent);
      color: black;
      border: none;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      justify-content: center;
      padding: 1.25rem 4rem;
      font-size: 1.125rem;
      font-weight: 600;
      display: flex;
      width: 100%;
      cursor: pointer;
      transition: all 0.2s;
    }
  }

  :global(.steppable-input) {
    display: flex;
    height: 35px;

    & :global(input) {
      width: 45px;
      text-align: center;
      border: none;
      border-top: 1px solid #000;
      border-bottom: 1px solid #000;
      font-size: 1rem;
      border-radius: 0;
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: textfield;
      margin: 0;
    }

    & :global(button) {
      width: 2rem;
      padding: 0;
      border: 1px solid #000;
      background-color: transparent;
      color: black;
      font-size: 1rem;
      font-weight: bold;
      text-align: center;
      cursor: pointer;
    }
  }
</style>
